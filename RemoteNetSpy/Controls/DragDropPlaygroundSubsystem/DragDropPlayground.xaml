<UserControl x:Class="DragDropExpressionBuilder.DragDropPlayground"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DragDropExpressionBuilder"
xmlns:models="clr-namespace:RemoteNetSpy.Models"
xmlns:convert="clr-namespace:DragDropExpressionBuilder.Converters"
xmlns:remoteconvert="clr-namespace:RemoteNetSpy.Converters"
xmlns:controls="clr-namespace:RemoteNetSpy.Controls"
mc:Ignorable="d" 
d:DesignHeight="450" d:DesignWidth="1000"
d:Background="{StaticResource ControlDarkerBorderBrush}"
d:DataContext="{x:Static local:DesignTimeData.DesignInstance}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RemoteNetSpy;component/ThemesFolder/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <convert:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <convert:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <convert:IsLastItemToVisibilityConverter x:Key="IsLastItemToVisibilityConverter"/>
            <remoteconvert:MethodInfoToFormattedTextConverter x:Key="MethodInfoToFormattedTextConverter"/>

            <Image x:Key="MethodIcon" x:Shared="False" Source="pack://application:,,,/Assets/Method.png" Width="16" Height="16"/>

            <DataTemplate x:Key="MethodInfoHeaderTemplate">
                <ContentControl Content="{Binding Converter={StaticResource MethodInfoToFormattedTextConverter}}"/>
            </DataTemplate>

            <Style x:Key="SearchableContextMenuStyle" TargetType="{x:Type controls:SearchableContextMenu}">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContextMenu}">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400"
                                              CanContentScroll="True">
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel IsVirtualizing="True"
                                                    VirtualizationMode="Recycling"/>
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <!-- Main Area -->
        <Border x:Name="MainAreaBorder" AllowDrop="True" Padding="8"
                Background="{StaticResource ControlDarkerBorderBrush}" Panel.ZIndex="0">
            <Canvas x:Name="MainAreaCanvas">
                <ItemsControl x:Name="MainAreaItemsControl" ItemsSource="{Binding DroppedMethods}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:DroppedMethodItem}">
                            <StackPanel Orientation="Horizontal">
                                <Grid>
                                    <Border Background="#53134C" Padding="6" CornerRadius="4" BorderBrush="#D237C0" BorderThickness="1"
                                    MouseLeftButtonDown="DroppedMethod_MouseLeftButtonDown"
                                    MouseMove="DroppedMethod_MouseMove"
                                    MouseLeftButtonUp="DroppedMethod_MouseLeftButtonUp">
                                        <StackPanel Orientation="Vertical">
                                            <StackPanel.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Cascadia Mono"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </StackPanel.Resources>
                                            <DockPanel LastChildFill="False">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" MinHeight="24">
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,1,0" >
                                                        <TextBlock Text="{Binding Invocation.Method.ReturnType}" FontWeight="Bold" Foreground="#4EC9B0" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Invocation.Method.Name}" FontWeight="Bold" Foreground="#DCDCAA" Margin="0,0,2,0"/>
                                                        <TextBlock Text="("/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Invocation.Parameters}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" MaxWidth="300"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <StackPanel.Resources>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="FontFamily" Value="Cascadia Mono"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Style>
                                                                    </StackPanel.Resources>
                                                                    <TextBlock Text="{Binding TypeName}" FontWeight="Bold" Foreground="#4EC9B0" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding ParamName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#7CD2FC" VerticalAlignment="Center"/>
                                                                    <TextBlock Text=":" FontWeight="Bold" Margin="0,0,2,0" VerticalAlignment="Center"/>
                                                                    <Border Background="White" Padding="2" CornerRadius="4" BorderBrush="#FFCCCCCC" BorderThickness="1"
                                                                                PreviewDrop="ParameterTextBox_PreviewDrop" PreviewDragOver="ParameterTextBox_PreviewDragOver" PreviewDragEnter="ParameterTextBox_PreviewDragOver">
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    PreviewMouseLeftButtonDown="MethodParameter_MouseButtonDown"
                                                                                    >
                                                                            <Image Source="pack://application:,,,/Assets/SelectObject.png" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding AssignedInstance.Tag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=[empty]}"
                                                                                           MinWidth="60" Margin="0,1,4,0" AllowDrop="True"
                                                                                           Foreground="#065C74"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- Potential comma after each parameter -->
                                                                    <TextBlock Text=","
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="2,0,0,0">
                                                                        <TextBlock.Visibility>
                                                                            <MultiBinding Converter="{StaticResource IsLastItemToVisibilityConverter}">
                                                                                <Binding />
                                                                                <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                            </MultiBinding>
                                                                        </TextBlock.Visibility>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text=")" Margin="0,0,0,4" VerticalAlignment="Bottom"/>
                                                </StackPanel>
                                            </DockPanel>
                                            <DockPanel>
                                                <Button Content="▶" DockPanel.Dock="Right" Command="{Binding Invocation.PlayCommand}" Margin="15,0,0,0" VerticalAlignment="Bottom" Padding="2,0"/>
                                                <Grid Visibility="{Binding Invocation.IsStatic, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    <StackPanel x:Name="instanceStackPanel" DataContext="{Binding Invocation.ThisInstance}" Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="Instance: " VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TypeName, FallbackValue=PlaceHolder}" FontWeight="Bold" Foreground="#4EC9B0" Margin="0,0,2,0" VerticalAlignment="Center"/>
                                                        <Border Background="White" Padding="2" CornerRadius="4" BorderBrush="#FFCCCCCC" BorderThickness="1"
                                                        PreviewDrop="ParameterTextBox_PreviewDrop" PreviewDragOver="ParameterTextBox_PreviewDragOver" PreviewDragEnter="ParameterTextBox_PreviewDragOver" 
                                                        >
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Source="pack://application:,,,/Assets/SelectObject.png" Margin="0,0,6,0"/>
                                                                <TextBlock Text="{Binding AssignedInstance.Tag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=[empty]}"
                                                                       MinWidth="60" Margin="0,1,4,0" AllowDrop="True"
                                                                   Foreground="#065C74"
                                                                   />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- "X" button -->
                                    <Border Width="20" Height="20"
                                                Background="#441122"
                                                CornerRadius="10"
                                                BorderBrush="DarkRed" BorderThickness="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,-10,-10,0"
                                                ClipToBounds="True">
                                        <Button Content="✕"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="White"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    Click="RemoveDroppedMethod_Click"
                                                    >
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="buttonBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="buttonBorder" Property="Background" Value="#771122"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="buttonBorder" Property="Background" Value="#331122"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Border>
                                </Grid>
                                <Border Background="#1C3413" Padding="6" CornerRadius="4" BorderBrush="#FF66CC99" BorderThickness="1"
                                        Margin="8,0,0,0"
                                            VerticalAlignment="Bottom"
                                        MouseLeftButtonDown="ResultPanel_MouseLeftButtonDown"
                                        MouseMove="DroppedMethod_MouseMove"
                                        MouseLeftButtonUp="DroppedMethod_MouseLeftButtonUp"
                                        Visibility="{Binding Invocation.ReturnValue, Converter={StaticResource NullToCollapsedConverter}}"
                                        >
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Returned: " Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <Border Background="#0C2C46" Padding="2" CornerRadius="4" BorderBrush="#2383D1" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/Assets/SelectObject.png" Margin="0,0,6,0" 
                                                       Visibility="{Binding Invocation.ReturnValue, Converter={StaticResource NullToCollapsedConverter}}"
                                                       />
                                                <TextBlock Text="{Binding Invocation.Method.ReturnType, FallbackValue=String}" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"
                                                               Foreground="#4EC9B0"
                                                               />
                                                <TextBlock Text="{Binding Invocation.ReturnValue.ParamName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=thisValue}" MinWidth="60" Margin="0,0,4,0"
                                                           Foreground="White"
                                                           MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Border>

        <!-- Reservoir -->
        <Border x:Name="ReservoirBorder" Margin="8" MinWidth="220" MinHeight="120" MaxHeight="220" HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="1000"
                Background="{StaticResource ControlDarkerBackground}">
            <GroupBox Header="Reservoir" Background="{StaticResource ControlDarkerBackground}">
                <ListBox x:Name="ReservoirListBox" AllowDrop="False" ItemsSource="{Binding ReservoirItems}" MinWidth="200"
                         Background="{StaticResource ControlDarkerBackground}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Resources>
                        <DataTemplate DataType="{x:Type models:HeapObjectViewModel}">
                            <StackPanel Orientation="Horizontal" MouseEnter="HeapObject_MouseEnter" MouseLeave="HeapObject_MouseLeave">
                                <Image Source="pack://application:,,,/Assets/SelectObject.png" Margin="0,0,6,0"/>
                                <TextBlock FontWeight="Bold">
                                    <Run Text="{Binding Description, Mode=OneWay}"/>
                                    <Run Text=" (" Foreground="Gray"/>
                                    <Run Text="{Binding HexAddress, Mode=OneWay}" Foreground="Gray"/>
                                    <Run Text=")" Foreground="Gray"/>
                                </TextBlock>
                                <Button Content="⋮" Width="22" Height="22" Margin="6,0,0,0" Padding="0" Cursor="Hand"
                                        Click="HeapObjectMethodsButton_Click">
                                    <Button.ContextMenu>
                                        <controls:SearchableContextMenu ItemsSource="{Binding TypeMethods}" 
                                                     Style="{StaticResource SearchableContextMenuStyle}"
                                                     Background="{StaticResource ControlDarkerBackground}"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                     BorderBrush="{StaticResource ControlDefaultBorderBrush}"
                                                     BorderThickness="1">
                                            <controls:SearchableContextMenu.ItemContainerStyle>
                                                <Style TargetType="MenuItem" BasedOn="{StaticResource darkThemeMenuItemStyleKey}">
                                                    <Setter Property="Tag" Value="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=controls:SearchableContextMenu}}"/>
                                                    <EventSetter Event="Click" Handler="MenuItem_Click"/>
                                                    <Setter Property="Icon" Value="{StaticResource MethodIcon}"/>
                                                    <Setter Property="HeaderTemplate" Value="{StaticResource MethodInfoHeaderTemplate}"/>
                                                </Style>
                                            </controls:SearchableContextMenu.ItemContainerStyle>
                                        </controls:SearchableContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.Resources>
                </ListBox>
            </GroupBox>
        </Border>
    </Grid>
</UserControl>
